	btn.MouseButton1Click:Connect(function()
		local ligado = callback(); if ligado ~= nil then btn.BackgroundColor3 = ligado and Color3.fromRGB(140, 0, 255) or Color3.fromRGB(25, 25, 25); avisar(texto .. (ligado and " LIGADO" or " DESLIGADO"), ligado and Color3.new(0, 1, 0) or Color3.new(1, 0, 0)) end
	end)
end

