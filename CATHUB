local function avisar(msg, cor)
    local t = Instance.new("TextLabel", notifFrame)
    t.Size = UDim2.new(1, 0, 0, 35)
    t.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
    t.TextColor3 = cor or Color3.new(1, 1, 1)
    t.Text = " [!] " .. msg
    t.Font = Enum.Font.GothamBold
    t.TextSize = 13
    Instance.new("UICorner", t)
    Instance.new("UIStroke", t).Color = cor or Color3.fromRGB(140, 0, 255)
    
    task.delay(4, function()
        for i = 0, 1, 0.1 do 
            if not t then break end
            t.BackgroundTransparency = i; t.TextTransparency = i; task.wait(0.05) 
        end
        if t then t:Destroy() end
    end)
end

