local function criarSlider(lStr, pos, min, max, callback)
	local l = Instance.new("TextLabel", mainFrame); l.Text = lStr .. ": 0"; l.Position = pos; l.Size = UDim2.new(1, 0, 0, 20); l.TextColor3 = Color3.new(0.7, 0.7, 0.7); l.BackgroundTransparency = 1
	local bg = Instance.new("Frame", mainFrame); bg.Size = UDim2.new(0.8, 0, 0, 5); bg.Position = pos + UDim2.new(0.1, 0, 0, 20); bg.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
	local s = Instance.new("TextButton", bg); s.Size = UDim2.new(0, 12, 0, 12); s.Position = UDim2.new(0, -6, 0.5, -6); s.Text = ""; s.BackgroundColor3 = Color3.fromRGB(180, 100, 255); Instance.new("UICorner", s).CornerRadius = UDim.new(1,0)
	local drag = false; s.MouseButton1Down:Connect(function() drag = true end)
	UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = false end end)
	RunService.RenderStepped:Connect(function() if drag then local rel = math.clamp((UserInputService:GetMouseLocation().X - bg.AbsolutePosition.X)/bg.AbsoluteSize.X, 0, 1); s.Position = UDim2.new(rel, -6, 0.5, -6); local val = min + (max-min)*rel; l.Text = lStr .. ": " .. math.floor(val); callback(val) end end)
end
