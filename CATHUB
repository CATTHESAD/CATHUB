-- LOOPS CORE
local bv, bg
function startFly() local r = player.Character.HumanoidRootPart; bg = Instance.new("BodyGyro", r); bg.maxTorque = Vector3.new(9e9, 9e9, 9e9); bv = Instance.new("BodyVelocity", r); bv.maxForce = Vector3.new(9e9, 9e9, 9e9) end
function stopFly() if bv then bv:Destroy() end if bg then bg:Destroy() end end

RunService.Stepped:Connect(function()
	local char = player.Character
	if char and char:FindFirstChild("HumanoidRootPart") then
		local r, h = char.HumanoidRootPart, char.Humanoid
		if walkSpeedMult > 0 and h.MoveDirection.Magnitude > 0 and not flyAtivo then r.CFrame = r.CFrame + (h.MoveDirection * (walkSpeedMult * 0.15)) end
		if flyAtivo and bv then
			local cam = workspace.CurrentCamera.CFrame; local d = Vector3.new(0,0,0)
			if UserInputService:IsKeyDown("W") then d = d + cam.LookVector end
			if UserInputService:IsKeyDown("S") then d = d - cam.LookVector end
			if UserInputService:IsKeyDown("A") then d = d - cam.RightVector end
			if UserInputService:IsKeyDown("D") then d = d + cam.RightVector end
            if UserInputService:IsKeyDown("E") then d = d + Vector3.new(0,1,0) end
            if UserInputService:IsKeyDown("Q") then d = d - Vector3.new(0,1,0) end
			bv.velocity = d * flySpeed; bg.cframe = cam
		end
		if noclipAtivo then h:ChangeState(11); for _, v in pairs(char:GetDescendants()) do if v:IsA("BasePart") then v.CanCollide = false end end 
		elseif not flyAtivo then for _, v in pairs(char:GetDescendants()) do if v:IsA("BasePart") then v.CanCollide = true end end end
	end
    -- OTIMIZAÇÃO DE ESP E STREAMER MODE
    for _, p in pairs(game.Players:GetPlayers()) do
        if p.Character and p.Character:FindFirstChild("Humanoid") then p.Character.Humanoid.DisplayName = streamerModeAtivo and "User" or p.DisplayName end
        if espAtivo and p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local dist = (player.Character.HumanoidRootPart.Position - p.Character.HumanoidRootPart.Position).Magnitude
            local h = p.Character:FindFirstChild("CatESP") or Instance.new("Highlight", p.Character)
            h.Name = "CatESP"; h.FillColor = Color3.fromRGB(140, 0, 255); h.Enabled = (dist < 1000) -- DISTANCIA SAFE
        end
    end
end)

function atualizarLista()
	for _, v in pairs(scroll:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
	for _, p in pairs(game.Players:GetPlayers()) do if p ~= player then
		local pBtn = Instance.new("TextButton", scroll); pBtn.Size = UDim2.new(1, -10, 0, 30); pBtn.Text = p.DisplayName; pBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 30); pBtn.TextColor3 = Color3.new(1, 1, 1); Instance.new("UICorner", pBtn)
		pBtn.MouseButton1Click:Connect(function() player.Character.HumanoidRootPart.CFrame = p.Character.HumanoidRootPart.CFrame end)
	end end
end
